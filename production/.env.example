# --- 3DCityDB connection (BYOD variant) ----------------------------------------
# For docker-compose.byod.yml: point at your existing 3DCityDB instance.
# For docker-compose.fullstack.yml: leave these blank; use POSTGRES_* below.

CITYDB_HOST=localhost
CITYDB_PORT=5432
CITYDB_NAME=citydb
CITYDB_USER=citydb
CITYDB_PASSWORD=citydb
CITYDB_SCHEMA=citydb

# --- PostgreSQL (fullstack variant only) ---------------------------------------
POSTGRES_DB=citydb
POSTGRES_USER=citydb
POSTGRES_PASSWORD=citydb
SRID=25832
POSTGIS_SFCGAL=true

# --- LLM provider -- set exactly one ------------------------------------------
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434
